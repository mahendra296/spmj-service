<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="SPMJ Foundation programs — free schooling, after-school learning, digital and STEM labs, scholarships, and child welfare." />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body data-page="<%= page %>">
  <%- include('header') %>

  <main>
    <section class="page-hero">
      <div class="container">
        <span class="eyebrow">Our programs</span>
        <h1 class="display">Support for <span class="grad">every step</span> of learning.</h1>
        <p class="lead">
          From a child's very first day of school to their first job, our programs
          work together to keep learners in school and help them flourish.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-3">
          <% programs.forEach((s) => { %>
            <article class="service-card">
              <div class="service-icon">
                <% if (s.icon === 'spark') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v6m0 8v6m10-10h-6M8 12H2m15.07-7.07-4.24 4.24M9.17 14.83l-4.24 4.24m0-14.14 4.24 4.24m5.66 5.66 4.24 4.24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'layers') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m12 3 9 5-9 5-9-5 9-5Zm-9 9 9 5 9-5m-18 4 9 5 9-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'code') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m8 8-4 4 4 4m8-8 4 4-4 4M14 4l-4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'chart') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20V8m6 12V4m6 16v-9m6 9V12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'cloud') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 18a5 5 0 1 1 .9-9.92A6 6 0 0 1 19 11a4 4 0 0 1-1 7.87" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'shield') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } %>
              </div>
              <h3><%= s.title %></h3>
              <p><%= s.description %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">How we work</span>
          <h2>How a child's journey unfolds.</h2>
        </div>
        <ol class="process">
          <li>
            <span class="step">01</span>
            <h3>Reach out</h3>
            <p>We work with families and communities to find children who are out of school or at risk of dropping out.</p>
          </li>
          <li>
            <span class="step">02</span>
            <h3>Enrol &amp; support</h3>
            <p>Each child joins a free learning centre with books, meals, and the support they need to start strong.</p>
          </li>
          <li>
            <span class="step">03</span>
            <h3>Learn &amp; grow</h3>
            <p>Through daily classes, digital labs, and mentoring, children build skills, confidence, and curiosity.</p>
          </li>
          <li>
            <span class="step">04</span>
            <h3>Thrive beyond</h3>
            <p>We stay with them — through scholarships and guidance — into higher education and meaningful work.</p>
          </li>
        </ol>
      </div>
    </section>

    <section class="section cta-section">
      <div class="container cta-card">
        <div>
          <h2>Not sure how to help?</h2>
          <p class="lead">Tell us a little about you — we'll suggest the best way to make a difference.</p>
        </div>
        <a href="/contact" class="btn btn-primary btn-lg">Get in touch →</a>
      </div>
    </section>
  </main>

  <%- include('footer') %>
  <script src="/script.js"></script>
</body>
</html>
