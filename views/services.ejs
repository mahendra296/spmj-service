<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="SPMG services — strategy, design, engineering, data, cloud, and security." />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body data-page="<%= page %>">
  <%- include('header') %>

  <main>
    <section class="page-hero">
      <div class="container">
        <span class="eyebrow">Services</span>
        <h1 class="display">A full-stack team for <span class="grad">every stage</span>.</h1>
        <p class="lead">
          Whether you're validating a new idea, scaling a growing product, or
          modernising a legacy stack — we have the people to make it happen.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-3">
          <% services.forEach((s) => { %>
            <article class="service-card">
              <div class="service-icon">
                <% if (s.icon === 'spark') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v6m0 8v6m10-10h-6M8 12H2m15.07-7.07-4.24 4.24M9.17 14.83l-4.24 4.24m0-14.14 4.24 4.24m5.66 5.66 4.24 4.24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'layers') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m12 3 9 5-9 5-9-5 9-5Zm-9 9 9 5 9-5m-18 4 9 5 9-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'code') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m8 8-4 4 4 4m8-8 4 4-4 4M14 4l-4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'chart') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20V8m6 12V4m6 16v-9m6 9V12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'cloud') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 18a5 5 0 1 1 .9-9.92A6 6 0 0 1 19 11a4 4 0 0 1-1 7.87" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'shield') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } %>
              </div>
              <h3><%= s.title %></h3>
              <p><%= s.description %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">How we work</span>
          <h2>A simple, proven process.</h2>
        </div>
        <ol class="process">
          <li>
            <span class="step">01</span>
            <h3>Discover</h3>
            <p>We spend time understanding your business, your users, and the problem we're solving — together.</p>
          </li>
          <li>
            <span class="step">02</span>
            <h3>Design</h3>
            <p>Rapid prototypes and tight feedback loops to find the right shape of the solution.</p>
          </li>
          <li>
            <span class="step">03</span>
            <h3>Build</h3>
            <p>Senior engineers ship production-quality software in weekly cycles, with full transparency.</p>
          </li>
          <li>
            <span class="step">04</span>
            <h3>Grow</h3>
            <p>We stick around — measuring, iterating, and helping your product compound over time.</p>
          </li>
        </ol>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Pricing</span>
          <h2>Honest, transparent engagements.</h2>
        </div>
        <div class="grid grid-3 pricing">
          <article class="price-card">
            <h3>Sprint</h3>
            <p class="price">$8k<span>/week</span></p>
            <p class="muted">Best for early validation and prototypes.</p>
            <ul class="checklist">
              <li>One senior designer + engineer</li>
              <li>Weekly demos</li>
              <li>Slack access</li>
              <li>2 week minimum</li>
            </ul>
          </article>
          <article class="price-card featured">
            <span class="tag">Most popular</span>
            <h3>Build</h3>
            <p class="price">$24k<span>/month</span></p>
            <p class="muted">A full pod focused on shipping your product.</p>
            <ul class="checklist">
              <li>Dedicated 3-person team</li>
              <li>Weekly sprints</li>
              <li>Async + live collaboration</li>
              <li>3 month minimum</li>
            </ul>
          </article>
          <article class="price-card">
            <h3>Partner</h3>
            <p class="price">Custom</p>
            <p class="muted">Long-term embedded teams for scaling products.</p>
            <ul class="checklist">
              <li>Custom team size</li>
              <li>Strategic roadmapping</li>
              <li>24/7 support</li>
              <li>Quarterly business reviews</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section cta-section">
      <div class="container cta-card">
        <div>
          <h2>Not sure which one fits?</h2>
          <p class="lead">Let's hop on a call — we'll point you in the right direction.</p>
        </div>
        <a href="/contact" class="btn btn-primary btn-lg">Get in touch →</a>
      </div>
    </section>
  </main>

  <%- include('footer') %>
  <script src="/script.js"></script>
</body>
</html>
