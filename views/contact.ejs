<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Contact SPMJ Foundation — donate, volunteer, or partner with us to bring education to every child." />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body data-page="<%= page %>">
  <%- include('header') %>

  <main>
    <section class="page-hero">
      <div class="container">
        <span class="eyebrow">Contact</span>
        <h1 class="display">Let's <span class="grad">talk</span>.</h1>
        <p class="lead">
          Want to donate, volunteer, partner with us, or simply learn more? We'd love to hear from you.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container two-col contact-wrap">
        <div class="contact-info">
          <h3>Reach us directly</h3>
          <p class="muted">We typically reply within two working days.</p>
          <ul class="contact-list">
            <li>
              <span class="contact-label">Email</span>
              <a href="mailto:hello@spmjfoundation.org">hello@spmjfoundation.org</a>
            </li>
            <li>
              <span class="contact-label">Phone</span>
              <a href="tel:+911123456789">+91 11 2345 6789</a>
            </li>
            <li>
              <span class="contact-label">Office</span>
              <span>SPMJ Foundation, 12 Vidya Marg<br />New Delhi 110001, India</span>
            </li>
            <li>
              <span class="contact-label">Hours</span>
              <span>Mon — Sat · 10am – 6pm IST</span>
            </li>
          </ul>
        </div>

        <div class="contact-form-wrap">
          <% if (sent) { %>
            <div class="alert success">
              <strong>Thank you — message received!</strong>
              <p>Our team will be in touch within two working days.</p>
            </div>
          <% } %>
          <form action="/contact" method="POST" class="contact-form" novalidate>
            <div class="form-row">
              <label for="name">Your name</label>
              <input type="text" id="name" name="name" placeholder="Jane Cooper"
                value="<%= (values && values.name) || '' %>" required />
              <% if (errors && errors.name) { %><span class="error"><%= errors.name %></span><% } %>
            </div>
            <div class="form-row">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com"
                value="<%= (values && values.email) || '' %>" required />
              <% if (errors && errors.email) { %><span class="error"><%= errors.email %></span><% } %>
            </div>
            <div class="form-row">
              <label for="message">How would you like to help?</label>
              <textarea id="message" name="message" rows="6" placeholder="Let us know if you'd like to donate, volunteer, partner with us, or simply learn more." required><%= (values && values.message) || '' %></textarea>
              <% if (errors && errors.message) { %><span class="error"><%= errors.message %></span><% } %>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">Send message →</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <%- include('footer') %>
  <script src="/script.js"></script>
</body>
</html>
