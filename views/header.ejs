<header class="site-header">
  <div class="container nav-container">
    <a href="/" class="brand" aria-label="SPMJ Foundation home">
      <span class="brand-mark">SPMJ</span>
      <span class="brand-dot"></span>
    </a>
    <nav class="primary-nav" aria-label="Primary">
      <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a>
      <a href="/about" class="<%= page === 'about' ? 'active' : '' %>">About</a>
      <a href="/services" class="<%= page === 'services' ? 'active' : '' %>">Programs</a>
      <a href="/events" class="<%= page === 'events' ? 'active' : '' %>">Events</a>
      <a href="/blog" class="<%= page === 'blog' ? 'active' : '' %>">Blog</a>
      <a href="/contact" class="<%= page === 'contact' ? 'active' : '' %>">Contact</a>
    </nav>
    <div class="nav-actions">
      <% if (user) { %>
        <a href="/admin/dashboard" class="btn btn-ghost">Dashboard</a>
        <form action="/admin/logout" method="POST" class="logout-form">
          <button type="submit" class="btn btn-ghost">Sign out</button>
        </form>
      <% } else { %>
        <a href="/admin/login" class="btn btn-ghost">Admin</a>
      <% } %>
      <a href="/donate" class="btn btn-primary <%= page === 'donate' ? 'active' : '' %>">Donate</a>
    </div>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
