<%- include('head', { title, active: 'dashboard' }) %>

    <div class="section-head" style="text-align:left;margin-bottom:32px;">
      <span class="eyebrow">Dashboard</span>
      <h1>Welcome back, <%= user.name %>.</h1>
      <p class="muted">Manage events, blog posts, and the photo &amp; video gallery.</p>
    </div>

    <div class="grid grid-3 stats-row">
      <a class="manage-card" href="/admin/events">
        <strong><%= counts.events %></strong>
        <span>Events</span>
        <span class="link-arrow">Manage events →</span>
      </a>
      <a class="manage-card" href="/admin/blog">
        <strong><%= counts.posts %></strong>
        <span>Blog &amp; news posts</span>
        <span class="link-arrow">Manage blog →</span>
      </a>
      <a class="manage-card" href="/admin/gallery">
        <strong><%= counts.gallery %></strong>
        <span>Gallery items</span>
        <span class="link-arrow">Manage gallery →</span>
      </a>
    </div>

    <div class="admin-panel">
      <h3>Quick actions</h3>
      <div class="hero-actions">
        <a href="/admin/events/new" class="btn btn-primary">+ New event</a>
        <a href="/admin/blog/new" class="btn btn-primary">+ New post</a>
        <a href="/admin/gallery/new" class="btn btn-primary">+ Add media</a>
      </div>
    </div>

<%- include('foot') %>
