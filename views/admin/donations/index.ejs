<%- include('../head', { title, active: 'donations' }) %>

    <div class="admin-list-head">
      <div>
        <span class="eyebrow">Donations</span>
        <h1>Donations</h1>
      </div>
      <div class="admin-list-actions">
        <%- include('../../partials/page-size', { pageSize, pageSizeOptions, pageSizeBaseUrl: '/admin/donations', pageSizeQuery: {} }) %>
        <a href="/admin/donations/export" class="btn btn-ghost">↓ Export CSV</a>
      </div>
    </div>

    <div class="stat-row">
      <div class="manage-card">
        <strong><%= fmt(stats.raisedPaise) %></strong>
        <span>Total raised</span>
      </div>
      <div class="manage-card">
        <strong><%= stats.paidCount.toLocaleString('en-IN') %></strong>
        <span>Successful donations</span>
      </div>
      <div class="manage-card">
        <strong><%= stats.totalCount.toLocaleString('en-IN') %></strong>
        <span>Total records</span>
      </div>
    </div>

    <div class="admin-panel">
      <% if (donations.length === 0) { %>
        <p class="muted">No donations yet.</p>
      <% } else { %>
        <div class="table-scroll">
          <table class="data-table data-table-rich">
            <thead>
              <tr>
                <th>Donor</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Reference</th>
                <th>Payment id</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% donations.forEach((d) => {
                const badge = d.status === 'paid' ? 'upcoming'
                  : d.status === 'failed' ? 'past'
                  : d.status === 'refunded' ? 'press' : 'draft';
              %>
                <tr>
                  <td>
                    <span class="table-title"><%= d.donorName %></span>
                    <span class="muted nowrap"><%= d.donorEmail %></span>
                  </td>
                  <td class="nowrap"><strong><%= fmt(d.amount, d.currency) %></strong></td>
                  <td><span class="badge badge-<%= badge %>"><%= d.status %></span></td>
                  <td class="nowrap"><%= d.receipt %></td>
                  <td class="nowrap"><%= d.razorpayPaymentId || '—' %></td>
                  <td class="nowrap"><%= new Date(d.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <%- include('../../partials/pagination', { pagination }) %>
      <% } %>
    </div>

<%- include('../foot') %>
