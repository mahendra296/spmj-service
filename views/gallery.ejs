<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Photos and videos from SPMJ Foundation events, camps, and learning centres." />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body data-page="<%= page %>">
  <%- include('header') %>

  <main>
    <section class="page-hero">
      <div class="container">
        <span class="eyebrow">Gallery</span>
        <h1 class="display">Moments that <span class="grad">matter</span>.</h1>
        <p class="lead">Photos and videos from our events, camps, and everyday life at the learning centres.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <% if (items.length === 0) { %>
          <p class="muted">No photos or videos have been added yet.</p>
        <% } else { %>
          <div class="gallery-grid">
            <% items.forEach((item) => { %>
              <figure class="gallery-item">
                <% if (item.mediaType === 'video') { %>
                  <% const isFile = item.mediaUrl.startsWith('/uploads/'); %>
                  <% if (isFile) { %>
                    <video controls preload="metadata" src="<%= item.mediaUrl %>"></video>
                  <% } else { %>
                    <div class="gallery-embed">
                      <a href="<%= item.mediaUrl %>" target="_blank" rel="noopener noreferrer" class="gallery-play" aria-label="Play video">
                        <span>▶</span>
                        <small>Watch video</small>
                      </a>
                    </div>
                  <% } %>
                <% } else { %>
                  <img src="<%= item.mediaUrl %>" alt="<%= item.title || item.caption || 'Gallery photo' %>" loading="lazy" />
                <% } %>
                <% if (item.title || item.caption || item.eventTitle) { %>
                  <figcaption>
                    <% if (item.title) { %><strong><%= item.title %></strong><% } %>
                    <% if (item.caption) { %><span><%= item.caption %></span><% } %>
                    <% if (item.eventTitle) { %><span class="gallery-tag"><%= item.eventTitle %></span><% } %>
                  </figcaption>
                <% } %>
              </figure>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('footer') %>
  <script src="/script.js"></script>
</body>
</html>
