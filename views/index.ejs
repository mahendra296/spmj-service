<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="SPMJ Foundation — a non-profit bringing free, quality education to underprivileged children through schooling, digital learning, and scholarships." />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body data-page="<%= page %>">
  <%- include('header') %>

  <main>
    <section class="slider" aria-roledescription="carousel" aria-label="Featured highlights">
      <div class="slides">
        <div class="slide is-active" style="background-image: url('/images/slide-1.svg')">
          <div class="container slide-content">
            <span class="eyebrow">Education · Equity · Opportunity</span>
            <h1 class="display">Every child deserves a <span class="grad">future</span>.</h1>
            <p class="lead">SPMJ Foundation brings free, quality education to children who would otherwise be left behind.</p>
          </div>
        </div>
        <div class="slide" style="background-image: url('/images/slide-2.svg')">
          <div class="container slide-content">
            <span class="eyebrow">Learning that lasts</span>
            <h1 class="display">From the classroom to <span class="grad">confidence</span>.</h1>
            <p class="lead">Schooling, after-school support, and mentoring that help first-generation learners stay in school and thrive.</p>
          </div>
        </div>
        <div class="slide" style="background-image: url('/images/slide-3.svg')">
          <div class="container slide-content">
            <span class="eyebrow">Skills for tomorrow</span>
            <h1 class="display">Curious. Capable. <span class="grad">Ready.</span></h1>
            <p class="lead">Digital and STEM labs that give every student the tools to learn, build, and dream bigger.</p>
          </div>
        </div>
      </div>
      <button class="slider-arrow prev" aria-label="Previous slide">&#8249;</button>
      <button class="slider-arrow next" aria-label="Next slide">&#8250;</button>
      <div class="slider-dots" role="tablist" aria-label="Slide navigation"></div>
      <div class="slider-progress"><span class="bar"></span></div>
    </section>

    <section class="section logos">
      <div class="container">
        <p class="logos-label">Supported by partners and well-wishers like</p>
        <div class="logos-row">
          <span>Asha Trust</span>
          <span>Vidya Fund</span>
          <span>Sahyog</span>
          <span>Jyoti&Co</span>
          <span>Prerna</span>
          <span>Udaan</span>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">What we do</span>
          <h2>A whole-child approach,<br />from first lesson to first job.</h2>
        </div>
        <div class="grid grid-3">
          <% programs.slice(0,6).forEach((s) => { %>
            <article class="service-card">
              <div class="service-icon">
                <% if (s.icon === 'spark') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v6m0 8v6m10-10h-6M8 12H2m15.07-7.07-4.24 4.24M9.17 14.83l-4.24 4.24m0-14.14 4.24 4.24m5.66 5.66 4.24 4.24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'layers') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m12 3 9 5-9 5-9-5 9-5Zm-9 9 9 5 9-5m-18 4 9 5 9-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'code') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m8 8-4 4 4 4m8-8 4 4-4 4M14 4l-4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'chart') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20V8m6 12V4m6 16v-9m6 9V12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                <% } else if (s.icon === 'cloud') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 18a5 5 0 1 1 .9-9.92A6 6 0 0 1 19 11a4 4 0 0 1-1 7.87" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } else if (s.icon === 'shield') { %>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                <% } %>
              </div>
              <h3><%= s.title %></h3>
              <p><%= s.description %></p>
              <a href="/services" class="link-arrow">Learn more →</a>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Voices from our community</span>
          <h2>Stories of change.</h2>
        </div>
        <div class="grid grid-3">
          <blockquote class="testimonial">
            <p>"My daughter is the first in our family to read and write. The learning centre gave her a future I never had."</p>
            <footer><strong>Priya M.</strong> · Parent, Learning Centre</footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"I joined the digital lab knowing nothing about computers. Today I'm studying to become a software engineer."</p>
            <footer><strong>Daniel R.</strong> · Scholarship student</footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"Volunteering here changed me as much as the children. You see hope grow, one lesson at a time."</p>
            <footer><strong>Lina S.</strong> · Volunteer teacher</footer>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="section cta-section">
      <div class="container cta-card">
        <div>
          <h2>Help send a child to school.</h2>
          <p class="lead">Donate, volunteer, or partner with us — every contribution opens a door to learning.</p>
        </div>
        <a href="/contact" class="btn btn-primary btn-lg">Get involved →</a>
      </div>
    </section>
  </main>

  <%- include('footer') %>
  <script src="/script.js"></script>
</body>
</html>
